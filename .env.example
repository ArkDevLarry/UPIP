APP_NAME=UPIP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=upip
DB_USERNAME=upip_user
DB_PASSWORD=

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# JWT
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# AI Inference Service (Python FastAPI)
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=

# Encryption
GENETIC_ENCRYPTION_KEY=
SPEECH_ENCRYPTION_KEY=
DB_ENCRYPTION_KEY=

# UPRS Weights (overridable via DB)
UPRS_CARDIO_WEIGHT=0.40
UPRS_METABOLIC_WEIGHT=0.35
UPRS_MENTAL_WEIGHT=0.25

# Alert thresholds
UPRS_LOW_THRESHOLD=0.33
UPRS_MODERATE_THRESHOLD=0.66

# Clinician notification
CLINICIAN_NOTIFY_CHANNEL=mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@upip.health
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (for encrypted data storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
